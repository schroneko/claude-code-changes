{
  "name": "claude-code-changes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "track": "node --import tsx src/main.ts track",
    "compare": "node --import tsx src/main.ts compare",
    "list": "node --import tsx src/main.ts list",
    "backfill": "node --import tsx src/main.ts backfill",
    "compare:fixture": "node --import tsx src/main.ts compare ../claude-code-analysis/versions/2.1.25 ../claude-code-analysis/versions/2.1.27",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "oxfmt": "^0.36.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
